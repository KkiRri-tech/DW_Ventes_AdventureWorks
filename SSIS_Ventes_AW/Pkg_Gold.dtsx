      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{032818B1-6F51-4BCD-B31A-9B0AB6343B96}"
          SQLTask:SqlStatementSource="SET IDENTITY_INSERT Gold.DimSalesPerson ON;&#xA;INSERT INTO Gold.DimSalesPerson (SalesPersonKey, SalesPersonID, FullName, TerritoryID, SalesQuota, CommissionPct)&#xA;VALUES (-1, -1, 'Online / No Salesperson', NULL, NULL, 0);&#xA;SET IDENTITY_INSERT Gold.DimSalesPerson OFF;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Load DimCustomer"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Tâche d'exécution de requêtes SQL"
      DTS:DTSID="{3a96d28b-8059-4f51-a695-3bb580d19974}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load DimCustomer"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{032818B1-6F51-4BCD-B31A-9B0AB6343B96}"
          SQLTask:SqlStatementSource="INSERT INTO Gold.DimCustomer (CustomerID, CustomerType, FullName, TerritoryID, StartDate, IsCurrent)&#xA;SELECT CustomerID, CustomerType, FullName, TerritoryID, GETDATE(), 1&#xA;FROM Silver.Customer;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Load DimProduct"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Tâche d'exécution de requêtes SQL"
      DTS:DTSID="{569c3774-257f-4b72-acf3-c9da1e175167}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load DimProduct"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{032818B1-6F51-4BCD-B31A-9B0AB6343B96}"
          SQLTask:SqlStatementSource="INSERT INTO Gold.DimProduct (ProductID, ProductName, Color, ProductLine,&#xA;                             SubcategoryName, CategoryName, StandardCost,&#xA;                             ListPrice, IsDiscontinued, StartDate, IsCurrent)&#xA;SELECT ProductID, ProductName, Color, ProductLine,&#xA;       SubcategoryName, CategoryName, StandardCost,&#xA;       ListPrice, IsDiscontinued, GETDATE(), 1&#xA;FROM Silver.Product;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Load DimSalesPerson"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Tâche d'exécution de requêtes SQL"
      DTS:DTSID="{a2afcee7-da39-47b6-ab12-e44d805271a0}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load DimSalesPerson"
