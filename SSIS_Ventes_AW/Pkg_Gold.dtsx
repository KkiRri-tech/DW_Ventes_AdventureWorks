        <SQLTask:SqlTaskData
          SQLTask:Connection="{032818B1-6F51-4BCD-B31A-9B0AB6343B96}"
          SQLTask:SqlStatementSource="INSERT INTO Gold.DimSalesPerson (SalesPersonID, FullName, TerritoryID, SalesQuota, CommissionPct)&#xA;SELECT SalesPersonID, FullName, TerritoryID, SalesQuota, CommissionPct&#xA;FROM Silver.SalesPerson;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
