  <DTS:Variables />
  <DTS:Executables>
    <DTS:Executable
      DTS:refId="Package\Load Customer"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Tâche d'exécution de requêtes SQL"
      DTS:DTSID="{0ea00ba6-e0a1-4d7d-8469-e3c2e49b5c92}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load Customer"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{E2E5531F-35F0-4A9E-8B2F-5B78F4188CDB}"
          SQLTask:SqlStatementSource="INSERT INTO Silver.Customer&#xA;SELECT&#xA;    c.CustomerID,&#xA;    CASE&#xA;        WHEN c.PersonID IS NOT NULL THEN 'Individual'&#xA;        WHEN c.StoreID  IS NOT NULL THEN 'Store'&#xA;        ELSE 'Unknown'&#xA;    END,&#xA;    ISNULL(LTRIM(RTRIM(&#xA;        ISNULL(p.FirstName,'') + ' ' +&#xA;        ISNULL(p.MiddleName+' ','') +&#xA;        ISNULL(p.LastName,'')&#xA;    )), 'Unknown'),&#xA;    c.TerritoryID,&#xA;    GETDATE()&#xA;FROM Bronze.Customer c&#xA;LEFT JOIN Bronze.Person p ON p.BusinessEntityID = c.PersonID&#xA;WHERE c.CustomerID IS NOT NULL;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Load Product"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Tâche d'exécution de requêtes SQL"
      DTS:DTSID="{e2eead7c-05e9-4bfe-b680-53ba624b7413}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load Product"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{E2E5531F-35F0-4A9E-8B2F-5B78F4188CDB}"
          SQLTask:SqlStatementSource="INSERT INTO Silver.Product&#xA;SELECT&#xA;    p.ProductID,&#xA;    ISNULL(p.Name, 'Unknown'),&#xA;    ISNULL(p.Color, 'N/A'),&#xA;    ISNULL(CAST(p.StandardCost AS DECIMAL(18,2)), 0),&#xA;    ISNULL(CAST(p.ListPrice    AS DECIMAL(18,2)), 0),&#xA;    CASE p.ProductLine&#xA;        WHEN 'R' THEN 'Road'&#xA;        WHEN 'M' THEN 'Mountain'&#xA;        WHEN 'T' THEN 'Touring'&#xA;        WHEN 'S' THEN 'Standard'&#xA;        ELSE 'N/A'&#xA;    END,&#xA;    ISNULL(sc.Name, 'Unknown'),&#xA;    ISNULL(cat.Name,'Unknown'),&#xA;    CASE WHEN p.SellEndDate IS NOT NULL THEN 1 ELSE 0 END,&#xA;    GETDATE()&#xA;FROM Bronze.Product p&#xA;LEFT JOIN Bronze.ProductSubcategory sc  ON sc.ProductSubcategoryID = p.ProductSubcategoryID&#xA;LEFT JOIN Bronze.ProductCategory    cat ON cat.ProductCategoryID   = sc.ProductCategoryID&#xA;WHERE p.ProductID IS NOT NULL;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Load SalesOrderDetail"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Tâche d'exécution de requêtes SQL"
      DTS:DTSID="{1257e80d-5ae3-44e8-82f8-4e26a7557456}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load SalesOrderDetail"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{E2E5531F-35F0-4A9E-8B2F-5B78F4188CDB}"
          SQLTask:SqlStatementSource="INSERT INTO Silver.SalesOrderDetail&#xA;SELECT&#xA;    SalesOrderDetailID,&#xA;    SalesOrderID,&#xA;    ProductID,&#xA;    ISNULL(SpecialOfferID, 1),&#xA;    OrderQty,&#xA;    CAST(UnitPrice         AS DECIMAL(18,2)),&#xA;    CAST(UnitPriceDiscount AS DECIMAL(5,4)),&#xA;    CAST(LineTotal         AS DECIMAL(18,2)),&#xA;    GETDATE()&#xA;FROM Bronze.SalesOrderDetail&#xA;WHERE SalesOrderDetailID IS NOT NULL&#xA;  AND SalesOrderID       IS NOT NULL&#xA;  AND ProductID          IS NOT NULL&#xA;  AND OrderQty &gt; 0;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Load SalesOrderHeader"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Tâche d'exécution de requêtes SQL"
      DTS:DTSID="{c7fc4f46-2204-410a-b3bf-1285bce02539}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load SalesOrderHeader"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{E2E5531F-35F0-4A9E-8B2F-5B78F4188CDB}"
          SQLTask:SqlStatementSource="INSERT INTO Silver.SalesOrderHeader&#xA;SELECT&#xA;    SalesOrderID,&#xA;    CAST(OrderDate AS DATE),&#xA;    CAST(ShipDate  AS DATE),&#xA;    YEAR(OrderDate),&#xA;    MONTH(OrderDate),&#xA;    DATEPART(QUARTER, OrderDate),&#xA;    OnlineOrderFlag,&#xA;    CustomerID,&#xA;    SalesPersonID,&#xA;    TerritoryID,&#xA;    CAST(SubTotal  AS DECIMAL(18,2)),&#xA;    CAST(TaxAmt    AS DECIMAL(18,2)),&#xA;    CAST(Freight   AS DECIMAL(18,2)),&#xA;    CAST(TotalDue  AS DECIMAL(18,2)),&#xA;    CASE Status&#xA;        WHEN 1 THEN 'In Process'&#xA;        WHEN 2 THEN 'Approved'&#xA;        WHEN 3 THEN 'Backordered'&#xA;        WHEN 4 THEN 'Rejected'&#xA;        WHEN 5 THEN 'Shipped'&#xA;        WHEN 6 THEN 'Cancelled'&#xA;        ELSE 'Unknown'&#xA;    END,&#xA;    GETDATE()&#xA;FROM Bronze.SalesOrderHeader&#xA;WHERE SalesOrderID IS NOT NULL&#xA;  AND OrderDate    IS NOT NULL&#xA;  AND CustomerID   IS NOT NULL;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Load SalesPerson"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Tâche d'exécution de requêtes SQL"
      DTS:DTSID="{04ac16f4-c25c-43d7-b92e-6b9b65b308de}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load SalesPerson"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{E2E5531F-35F0-4A9E-8B2F-5B78F4188CDB}"
          SQLTask:SqlStatementSource="INSERT INTO Silver.SalesPerson&#xA;SELECT&#xA;    sp.BusinessEntityID,&#xA;    ISNULL(LTRIM(RTRIM(&#xA;        ISNULL(p.FirstName,'') + ' ' +&#xA;        ISNULL(p.LastName,'')&#xA;    )), 'Unknown'),&#xA;    sp.TerritoryID,&#xA;    CAST(ISNULL(sp.SalesQuota, 0)    AS DECIMAL(18,2)),&#xA;    CAST(ISNULL(sp.CommissionPct, 0) AS DECIMAL(5,4)),&#xA;    GETDATE()&#xA;FROM Bronze.SalesPerson sp&#xA;LEFT JOIN Bronze.Person p ON p.BusinessEntityID = sp.BusinessEntityID&#xA;WHERE sp.BusinessEntityID IS NOT NULL;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Load Territory"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Tâche d'exécution de requêtes SQL"
      DTS:DTSID="{988e602f-cfe4-418a-8add-900e5e1622b0}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load Territory"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{E2E5531F-35F0-4A9E-8B2F-5B78F4188CDB}"
          SQLTask:SqlStatementSource="INSERT INTO Silver.Territory&#xA;SELECT&#xA;    TerritoryID, Name, CountryRegionCode, [Group], GETDATE()&#xA;FROM Bronze.SalesTerritory&#xA;WHERE TerritoryID IS NOT NULL;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Truncate Silver"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Tâche d'exécution de requêtes SQL"
      DTS:DTSID="{3EA2325A-C19C-4A8C-9ACA-A00CDD66BF4B}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Truncate Silver"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{E2E5531F-35F0-4A9E-8B2F-5B78F4188CDB}"
          SQLTask:SqlStatementSource="DELETE FROM Silver.SalesOrderDetail;&#xA;DELETE FROM Silver.SalesOrderHeader;&#xA;DELETE FROM Silver.Customer;&#xA;DELETE FROM Silver.Product;&#xA;DELETE FROM Silver.Territory;&#xA;DELETE FROM Silver.SalesPerson;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
